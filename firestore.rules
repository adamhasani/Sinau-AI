rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Common Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // User Profile
    match /users/{userId} {
      function isValidUser(data) {
        return data.xp is number && data.level is number && 
               data.uid == request.auth.uid;
      }
      
      allow get: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['xp', 'level', 'studyTimeSeconds', 'dailyStreak', 'lastActive', 'photoURL', 'displayName', 'email'])
      );
    }

    // Study Packs
    match /studyPacks/{packId} {
      function isValidPack(data) {
        return data.userId == request.auth.uid && 
               data.topic is string && data.topic.size() <= 200;
      }
      
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidPack(request.resource.data);
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Sessions
    match /users/{userId}/sessions/{sessionId} {
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
    }
  }
}
